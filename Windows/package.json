{
  "name": "video-watermark-app",
  "version": "1.0.2",
  "description": "批量视频添加水印工具",
  "author": "Raz1ner",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --mac --win --arm64 --x64"
  },
  "build": {
    "appId": "com.Raz1ner.VideoWatermark",
    "productName": "视频加水印工具",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.ico"
    },
    "asarUnpack": [
      "fonts/**",
      "bin/**",
      "**/*.node"
    ]
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.88",
    "fluent-ffmpeg": "latest",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "latest"
  }
}
